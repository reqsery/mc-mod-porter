{
  "schemaVersion": 1,
  "id": "porting_lib_base",
  "version": "${version}",
  "name": "Porting Lib Base",
  "description": "Assorted utilities for porting mods from Forge to Fabric, awaiting further sorting into modules.",
  "entrypoints": {
    "main": [
      "io.github.fabricators_of_create.porting_lib.PortingLibBase"
    ],
    "client": [
      "io.github.fabricators_of_create.porting_lib.PortingLibBaseClient"
    ]
  },
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/class_276": ["io/github/fabricators_of_create/porting_lib/extensions/client/RenderTargetExtension"],
      "net/minecraft/class_1058": ["io/github/fabricators_of_create/porting_lib/extensions/client/TextureAtlasSpriteExtension"],
      "net/minecraft/class_1044": ["io/github/fabricators_of_create/porting_lib/extensions/client/AbstractTextureExtension"],
      "net/minecraft/class_1735": ["io/github/fabricators_of_create/porting_lib/extensions/common/SlotExtension"],
      "net/minecraft/class_1834": ["io/github/fabricators_of_create/porting_lib/extensions/common/TiersExtension"],
      "net/minecraft/class_1937": ["io/github/fabricators_of_create/porting_lib/extensions/common/LevelExtensions"],
      "net/minecraft/class_2960": ["io/github/fabricators_of_create/porting_lib/extensions/common/ResourceLocationExtension"],
      "net/minecraft/class_3491": ["io/github/fabricators_of_create/porting_lib/extensions/common/StructureProcessorExtension"],
      "net/minecraft/class_4587": ["io/github/fabricators_of_create/porting_lib/extensions/client/PoseStackExtension"],
      "net/minecraft/class_2474$class_5124": ["io/github/fabricators_of_create/porting_lib/extensions/common/TagAppenderExtension<TT;>"]
    }
  }
}
