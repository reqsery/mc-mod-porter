{
  "schemaVersion": 1,
  "id": "porting_lib_items",
  "version": "${version}",
  "name": "Porting Lib Items",
  "description": "Adds extra item extensions",
  "entrypoints": {
    "client": [
      "io.github.fabricators_of_create.porting_lib.item.client.ItemDecoratorHandler::init"
    ]
  },
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/class_1792$class_1793": ["io/github/fabricators_of_create/porting_lib/item/injects/ItemPropertiesInjection"],
      "net/minecraft/class_1799": ["io/github/fabricators_of_create/porting_lib/item/injects/ItemStackInjection"],
      "net/minecraft/class_9288": ["io/github/fabricators_of_create/porting_lib/item/injects/ItemContainerContentsInjection"]
    }
  }
}
