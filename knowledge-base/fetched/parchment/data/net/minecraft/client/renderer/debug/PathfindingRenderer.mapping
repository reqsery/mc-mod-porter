		ARG 2 renderNodes
		ARG 3 renderInfo
		ARG 4 camX
		ARG 6 camY
		ARG 8 camZ
	METHOD renderPathLine (Lcom/mojang/blaze3d/vertex/PoseStack;Lcom/mojang/blaze3d/vertex/VertexConsumer;Lnet/minecraft/world/level/pathfinder/Path;DDD)V
		ARG 0 poseStack
		ARG 1 consumer
		ARG 2 path
		ARG 3 x
		ARG 5 y
		ARG 7 z
	METHOD renderPathLine (Lnet/minecraft/world/level/pathfinder/Path;DDD)V
