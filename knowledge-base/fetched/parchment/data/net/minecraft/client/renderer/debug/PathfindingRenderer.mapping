CLASS net/minecraft/client/renderer/debug/PathfindingRenderer
	METHOD distanceToCamera (Lnet/minecraft/core/BlockPos;DDD)F
		ARG 0 pos
		ARG 1 x
		ARG 3 y
		ARG 5 z
	METHOD renderPath (DDDLnet/minecraft/world/level/pathfinder/Path;F)V
		ARG 0 camX
		ARG 2 camY
		ARG 4 camZ
		ARG 6 path
		ARG 7 maxNodeDistance
	METHOD renderPath (Lcom/mojang/blaze3d/vertex/PoseStack;Lnet/minecraft/client/renderer/MultiBufferSource;DDDLnet/minecraft/world/level/pathfinder/Path;F)V
		ARG 0 poseStack
		ARG 1 bufferSource
		ARG 2 x
		ARG 4 y
		ARG 6 z
		ARG 8 path
		ARG 9 nodeSize
	METHOD renderPath (Lcom/mojang/blaze3d/vertex/PoseStack;Lnet/minecraft/client/renderer/MultiBufferSource;Lnet/minecraft/world/level/pathfinder/Path;FZZDDD)V
		ARG 0 poseStack
		ARG 1 bufferSource
		ARG 2 path
		ARG 3 nodeSize
		ARG 4 renderDebugNodes
		ARG 5 renderDebugInfo
		ARG 6 x
		ARG 8 y
		ARG 10 z
	METHOD renderPath (Lnet/minecraft/world/level/pathfinder/Path;FZZDDD)V
		ARG 0 path
